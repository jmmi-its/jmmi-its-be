generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum FinanceType {
  income
  expenses
}

model Category {
  id        String   @id @default(uuid())
  title     String
  weight    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  folders   Folder[]
  links     Link[]

  @@map("categories")
}

model Folder {
  id          String       @id @default(uuid())
  categoryId  String       @map("category_id")
  title       String
  weight      Int          @default(0)
  createdAt   DateTime     @default(now()) @map("created_at")
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subheadings Subheading[]
  links       Link[]

  @@map("folders")
}

model Subheading {
  id        String   @id @default(uuid())
  folderId  String   @map("folder_id")
  title     String
  weight    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  folder    Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)
  links     Link[]

  @@map("subheadings")
}

model Link {
  id           String      @id @default(uuid())
  categoryId   String?     @map("category_id")
  folderId     String?     @map("folder_id")
  subheadingId String?     @map("subheading_id")
  title        String
  url          String
  weight       Int         @default(0)
  createdAt    DateTime    @default(now()) @map("created_at")
  category     Category?   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  folder       Folder?     @relation(fields: [folderId], references: [id], onDelete: Cascade)
  subheading   Subheading? @relation(fields: [subheadingId], references: [id], onDelete: Cascade)

  @@map("links")
}

model StaffAnnouncement {
  id        String    @id @default(uuid())
  nrp       String    @unique
  name      String
  codename  String
  createdAt DateTime  @default(now()) @map("created_at")
  viewedAt  DateTime? @map("viewed_at")

  @@index([nrp])
  @@map("staff_announcements")
}

model FinanceTransaction {
  id            String      @id @default(uuid())
  type          FinanceType
  description   String
  amount        Int
  transactionAt DateTime    @map("transaction_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@index([transactionAt])
  @@index([type])
  @@map("finance_transactions")
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@map("admins")
}

model CalendarEvent {
  id         String   @id @default(uuid())
  eventName  String   @map("event_name")
  eventDate  DateTime @map("event_date")
  eventTime  String   @map("event_time")
  location   String
  isRecurring Boolean @default(false) @map("is_recurring")
  recurrenceType String? @map("recurrence_type")
  recurrenceInterval Int @default(1) @map("recurrence_interval")
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([eventDate])
  @@index([eventDate, eventTime])
  @@map("calendar_events")
}
